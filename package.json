{
  "name": "codex-coms",
  "version": "1.0.0",
  "description": "Skills-first communication layer for two Codex agents over WebSocket.",
  "type": "module",
  "main": "dist/src/index.js",
  "engines": {
    "node": ">=22.12.0"
  },
  "bin": {
    "codex-coms": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "docs",
    ".agents/skills/codex-coms"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/mark-cli-executable.mjs",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "demo": "tsx src/cli.ts demo"
  },
  "keywords": [
    "codex",
    "agents",
    "websocket",
    "collaboration"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^15.0.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
